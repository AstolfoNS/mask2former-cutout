      }
    ],
    "cityscapes": [
      {
        "name": "cityscapes_train",
        "left_img_root": "ai-core/data/sources/cityscapes/leftImg8bit/train",
        "gtfine_root": "ai-core/data/sources/cityscapes/gtFine/train"
      }
    ],
    "semantic": [],
    "negative": []
  }
}
